# ======================================
# Python 项目规范 .gitignore
# ======================================

# ——— 环境变量与密钥（最关键：绝对不要提交 API Key！） ———
.env
.env.local
.env.*.local

# ——— Python 虚拟环境 ———
.venv/
venv/
ENV/
env/

# ——— Python 编译缓存 ———
__pycache__/
*.py[cod]
*$py.class
__pypackages__/

# ——— Python 打包与构建产物 ———
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
share/python-wheels/

# ——— 测试与调试相关 ———
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.pytest/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ——— 类型检查缓存 ———
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ——— Jupyter Notebook ———
.ipynb_checkpoints
*.ipynb

# ——— IDE / 编辑器 ———
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ——— 操作系统产生的文件 ———
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ——— 智能体数据（用户记忆、本地文件） ———
data/
local-*.md

# ——— 日志文件 ———
logs/
*.log